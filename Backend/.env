# Application
NODE_ENV=development
PORT=5000

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SUPABASE_STORAGE_BUCKET=watch-images

# Auth
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# Frontend (CORS origin)
FRONTEND_URL=http://localhost:5013

# Stripe (Optional — leave empty if not using)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_GENERAL=100
RATE_LIMIT_MAX_AUTH=10
RATE_LIMIT_MAX_UPLOAD=20
RATE_LIMIT_UPLOAD_WINDOW_MS=3600000

# Logging
LOG_LEVEL=info
